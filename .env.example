# PostgreSQL
POSTGRES_USER=grocery
POSTGRES_PASSWORD=grocery_dev
POSTGRES_DB=grocery_receipt

# Backend
DATABASE_URL=postgresql+asyncpg://grocery:grocery_dev@db:5432/grocery_receipt
DATABASE_URL_TEST=postgresql+asyncpg://grocery:grocery_dev@db:5432/grocery_receipt_test
SECRET_KEY=change-me-in-production
DEBUG=true

# Gemini AI (extracción de tickets)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash-lite

# Google Drive (sync automático de tickets)
GOOGLE_DRIVE_CREDENTIALS_PATH=credentials/service-account.json
GOOGLE_DRIVE_FOLDER_ID=your-folder-id-here

# Límite de llamadas a Gemini por sync (0 = ilimitado)
GEMINI_BATCH_LIMIT=0
